{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Coldhands: New note",
      "type": "shell",
      "command": ".\\new-note.cmd",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Coldhands: Preview",
      "type": "shell",
      "command": "corepack pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Coldhands: Publish",
      "type": "shell",
      "command": ".\\publish.cmd",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}